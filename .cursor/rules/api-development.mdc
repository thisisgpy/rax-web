# API 开发规范

## 统一响应格式
所有API接口必须遵循统一的响应格式：

```typescript
// src/types/api.d.ts
/** API统一响应结构 */
interface ApiResponse<T = any> {
  /** 是否成功 */
  success: boolean
  /** 响应消息 */
  message: string
  /** 响应数据 */
  data: T
}

/** 分页查询参数 */
interface PaginationParams {
  /** 页码 */
  page: number
  /** 每页数量 */
  pageSize: number
}

/** 分页响应数据 */
interface PaginationData<T> {
  list: T[]
  total: number
  page: number
  pageSize: number
}
```

## HTTP 客户端配置

### Axios 标准配置
```typescript
// src/api/httpClient.ts
import axios from 'axios'
import { ElMessage } from 'element-plus'

const httpClient = axios.create({
  baseURL: import.meta.env.VITE_API_BASE_URL || '/api',
  timeout: 10000,
  headers: { 'Content-Type': 'application/json' }
})

// 请求拦截器
httpClient.interceptors.request.use((config) => {
  const token = localStorage.getItem('token')
  if (token) {
    config.headers.Authorization = `Bearer ${token}`
  }
  // GET请求添加时间戳防缓存
  if (config.method === 'get') {
    config.params = { ...config.params, _t: Date.now() }
  }
  return config
})

// 响应拦截器
httpClient.interceptors.response.use(
  (response) => response.data,
  (error) => {
    const status = error.response?.status
    if (status === 401) {
      localStorage.removeItem('token')
      ElMessage.error('登录已过期，请重新登录')
      // 跳转登录页
    } else if (status === 403) {
      ElMessage.error('没有访问权限')
    } else if (status >= 500) {
      ElMessage.error('服务器错误，请稍后重试')
    }
    return Promise.reject(error)
  }
)

export default httpClient
```

## API 接口模块化

### 接口模块组织
```typescript
// src/api/modules/user.ts
import httpClient from '../httpClient'
import type { User, UserListParams, CreateUserDto } from '@/types/user'

export const userApi = {
  /**
   * 获取用户列表
   */
  getUserList(params: UserListParams): Promise<ApiResponse<PaginationData<User>>> {
    return httpClient.get('/users', { params })
  },

  /**
   * 获取用户详情
   */
  getUserDetail(id: string): Promise<ApiResponse<User>> {
    return httpClient.get(`/users/${id}`)
  },

  /**
   * 创建用户
   */
  createUser(data: CreateUserDto): Promise<ApiResponse<User>> {
    return httpClient.post('/users', data)
  },

  /**
   * 更新用户
   */
  updateUser(id: string, data: Partial<CreateUserDto>): Promise<ApiResponse<User>> {
    return httpClient.put(`/users/${id}`, data)
  },

  /**
   * 删除用户
   */
  deleteUser(id: string): Promise<ApiResponse<void>> {
    return httpClient.delete(`/users/${id}`)
  }
}
```

### API 统一导出
```typescript
// src/api/index.ts
export { userApi } from './modules/user'
export { authApi } from './modules/auth'
export { orgApi } from './modules/org'
